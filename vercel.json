{
  "version": 2,
  "public": true,
  "functions": {
    "api/og.ts": {
      "memory": 1024,
      "maxDuration": 10
    },
    "api/cert.ts": {
      "memory": 512
    },
    "api/evidence-pack.ts": {
      "maxDuration": 30
    },
    "api/generate-evidence-pack.ts": {
      "maxDuration": 60
    },
    "api/timestamp.ts": {
      "maxDuration": 30
    },
    "api/webhooks/stripe.ts": {
      "maxDuration": 30
    },
    "api/cron/cleanup-spot-data.ts": {
      "maxDuration": 60
    },
    "api/storefront-html.ts": {
      "includeFiles": "dist/index.html"
    }
  },
  "rewrites": [
    {
      "source": "/cert/:id",
      "destination": "/api/cert?id=:id"
    },
    {
      "source": "/u/:username",
      "destination": "/api/storefront-html?username=:username"
    },
    {
      "source": "/((?!api/|cert/|u/|@|src/|node_modules/)[^.]*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/embed/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/api/certificates/widget/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/evidence-pack",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=0, must-revalidate"
        },
        {
          "key": "Access-Control-Expose-Headers",
          "value": "Content-Disposition, X-Request-Id, X-Evidence-Cert-Id, X-Evidence-Trust-Tier"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-spot-data",
      "schedule": "0 * * * *"
    }
  ]
}