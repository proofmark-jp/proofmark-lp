+// ---- RFC3161 FreeTSA Timestamp API ----
+// NOTE: api/timestamp.ts v2.1 はサーバー側で SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY を
+// 環境変数から取得し、ユーザー識別は JWT のみで完結する。
+// 旧仕様で必要だった `apikey` / `x-supabase-url` のクライアント送信は、ゼロトラスト設計上
+// 脆弱性源であるため完全に撤廃する（開発戦記 §21 準拠）。
+const applyRFC3161Timestamp = async (certId: string, hash: string) => {
+  const { data: { session } } = await supabase.auth.getSession();
+  if (!session?.access_token) {
+    throw new Error('セッションが切れています。再ログインしてください。');
+  }
+  const response = await fetch('/api/timestamp', {
+    method: 'POST',
+    headers: {
+      'Content-Type': 'application/json',
+      Authorization: `Bearer ${session.access_token}`,
+    },
+    credentials: 'omit',
+    body: JSON.stringify({ certId, hash }),
+  });
+  if (!response.ok) {
+    let msg = `HTTP ${response.status}`;
+    try {
+      const j = await response.json();
+      if (j?.error) msg = `${j.error}${j.reqId ? ` (req: ${j.reqId})` : ''}`;
+    } catch { /* non-JSON */ }
+    throw new Error(msg);
+  }
+  return response.json();
+};
