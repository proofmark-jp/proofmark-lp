+  const handleDownloadEvidencePack = useCallback(async (cert: Certificate) => {
+    // Evidence Pack: PDF 証明書 + RFC3161 TST(.tsr) + 独立検証スクリプト + カバーレター草案 を
+    // ZIP 1 本で返すサーバー権威 API。Authorization: Bearer <JWT> のみを送り、
+    // apikey / x-supabase-url などのクライアントハックは一切使わない（ゼロトラスト）。
+    const toastId = toast.loading("Evidence Pack を生成中...");
+    try {
+      const { data: { session } } = await supabase.auth.getSession();
+      if (!session?.access_token) {
+        toast.error("セッションが切れています。再ログインしてください。", { id: toastId });
+        return;
+      }
+
+      const res = await fetch(`/api/evidence-pack?certId=${encodeURIComponent(cert.id)}`, {
+        method: "GET",
+        headers: {
+          Authorization: `Bearer ${session.access_token}`,
+          Accept: "application/zip",
+        },
+        credentials: "omit",
+      });
+
+      if (!res.ok) {
+        // サーバーは { error, reqId } を返す。reqId をトーストに出して Runtime Logs と一致させる。
+        let msg = `HTTP ${res.status}`;
+        try {
+          const j = await res.json();
+          if (j?.error) msg = `${j.error}${j.reqId ? ` (req: ${j.reqId})` : ""}`;
+        } catch { /* non-JSON body */ }
+        throw new Error(msg);
+      }
+
+      // Content-Disposition からファイル名を取り出す（filename*= 優先、無ければ filename=、最後に fallback）
+      const cd = res.headers.get("content-disposition") || "";
+      const m5987 = /filename\*\s*=\s*UTF-8''([^;]+)/i.exec(cd);
+      const mPlain = /filename\s*=\s*"?([^";]+)"?/i.exec(cd);
+      const filename = m5987
+        ? decodeURIComponent(m5987[1])
+        : mPlain
+        ? mPlain[1]
+        : `proofmark-evidence-${cert.id.slice(0, 8)}.zip`;
+
+      const blob = await res.blob();
+      const href = URL.createObjectURL(blob);
+      const a = document.createElement("a");
+      a.href = href;
+      a.download = filename;
+      document.body.appendChild(a);
+      a.click();
+      a.remove();
+      // メモリリーク回避のため URL を解放
+      setTimeout(() => URL.revokeObjectURL(href), 60_000);
+
+      toast.success("Evidence Pack をダウンロードしました", {
+        id: toastId,
+        description: filename,
+      });
+    } catch (e: any) {
+      toast.error("Evidence Pack の生成に失敗しました", {
+        id: toastId,
+        description: e?.message ?? "時間を置いて再試行してください。",
+      });
+    }
+  }, []);
