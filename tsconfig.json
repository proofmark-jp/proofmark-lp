{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      // 【絶対座標の定義】
      // Next.jsのコンパイラに対し、「@/」から始まるパスは「プロジェクトルートの src/」配下のみを
      // 探索するよう絶対命令を下す。Vite側のエイリアス設定とはここで完全に決別する。
      "@/*": ["./src/*"]
    }
  },
  // 【Next.jsの管轄エリア】
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  // 【物理遮断（The Quarantine）】
  // Next.jsのコンパイラと型チェッカーから、Viteの遺産（client）や過去のビルド結果を物理的に隠蔽する。
  // これにより、Next.jsがViteのコードを誤って解釈・コンパイルして自爆するリスクを根絶する。
  "exclude": [
    "node_modules",
    "client",
    "dist",
    "build",
    "supabase"
  ]
}